<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>sharewithme</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css">
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css">
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/fill/style.css">
  <style>
    html, body { margin: 0; padding: 0; min-height: 100%; }
    body { font-family: 'IBM Plex Sans', Helvetica, Arial, sans-serif; color: #2b2723; -webkit-font-smoothing: antialiased; }
    input::placeholder { color: #a39c92; }
    #url-input:focus { border-color: #7a746b; }
    #upload-button:hover { background: #e05a05; }
    #upload-button:active { background: #cc5204; }
    /* The file input is the whole drop zone; its native "Choose File" row can't be
       centered by CSS, so it is hidden and the overlay div shows the state instead. */
    #file-input { color: transparent; }
    #file-input::file-selector-button { display: none; }
    #file-input:hover { border-color: #f2650a; background: #fdebdd; }
    #file-input:valid { border-color: #7cb08a; background: #f2f7f3; }
    #file-input + div .file-selected { display: none; }
    #file-input:valid + div .file-selected { display: block; }
    #file-input:valid + div .file-empty { display: none; }
  </style>
</head>

<body>
  <div class="min-h-screen flex flex-col relative overflow-hidden" style="background: linear-gradient(160deg, #f6f3ec 0%, #f0ede6 45%, #e9e9e2 100%);">

    <!-- Decorative glows -->
    <div class="pointer-events-none absolute -top-32 -right-24 w-96 h-96 rounded-full blur-3xl opacity-40" style="background: radial-gradient(circle, #f9a366 0%, transparent 70%);"></div>
    <div class="pointer-events-none absolute -bottom-40 -left-24 w-96 h-96 rounded-full blur-3xl opacity-30" style="background: radial-gradient(circle, #f2650a 0%, transparent 70%);"></div>

    <!-- Top bar -->
    <header class="relative z-10 flex items-center gap-3 px-8 py-5">
      <div class="w-9 h-9 rounded-lg flex items-center justify-center shadow-sm" style="background: #f2650a;">
        <i class="ph-fill ph-share-network text-white text-lg"></i>
      </div>
      <span class="font-semibold tracking-tight" style="color: #2b2723;">sharewithme</span>
      <span class="ml-auto inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full" style="background: #fdebdd; color: #c2520a;"><i class="ph-fill ph-lightning"></i>Beta</span>
    </header>

    {{$body}}
    {{/body}}

    <!-- Footer -->
    <footer class="relative z-10 border-t px-8 py-6" style="border-color: #e6e0d6;">
      <div class="max-w-xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3 text-sm" style="color: #8a827a;">
        <div class="flex items-center gap-2">
          <i class="ph-fill ph-share-network" style="color: #f2650a;"></i>
          <span>© 2026 sharewithme</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="#" class="hover:opacity-70 transition">Privacy</a>
          <a href="#" class="hover:opacity-70 transition">Terms</a>
          <a href="https://github.com/kicsipixel/sahrewithme" class="inline-flex items-center gap-1.5 hover:opacity-70 transition"><i class="ph ph-github-logo"></i>GitHub</a>
        </div>
      </div>
    </footer>

  </div>
</body>

</html>
